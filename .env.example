DEBUG=true

# JWT — must match the secret in lunor-auth exactly
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/lunor_circle

# Redis (internal)
REDIS_URL=redis://redis:6379

# Event bus Redis (shared across all Lunor services — runs in lunor-nginx on host port 6380)
EVENT_BUS_URL=redis://host.docker.internal:6380/0
