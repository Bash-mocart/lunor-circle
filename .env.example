DEBUG=true

# JWT — must match the secret in lunor-auth exactly
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/lunor_circle

# Redis (internal)
REDIS_URL=redis://redis:6379

# Event bus Redis (shared across all Lunor services — runs in lunor-nginx on host port 6380)
EVENT_BUS_URL=redis://172.17.0.1:6380/0

# LiveKit voice rooms — must match livekit.yaml keys config
LIVEKIT_API_KEY=lunorkey
LIVEKIT_API_SECRET=change_me_to_match_livekit_yaml
LIVEKIT_URL=wss://voice.lunor.money
